{
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5000"
      }
    }
  },
  "ConnectionStrings": {
    "Default": "Data Source=data/hamstats.db",
  },
  "CallsignLookup": {
    "Enabled": true,
    "CacheDirectory": "data/callsign-cache",
    "MaxCacheAge": "7.00:00:00",
    "RefreshCron": "0 3 * * 0",
    "BuildOnStartup": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "HamStats.Website.HostedServices": "Debug",
      "Microsoft.Hosting.Lifetime": "Information"
    },
    "AsioAppLog": {
      "LogLevel": {
        "Default": "Warning",
        "HamStats.Website.HostedServices": "Trace"
      }
    },
    "Asio": {
      "LogLevel": {
        "Default": "Information",
        "HamStats.Website.CallsignLookup": "Debug"
      }
    }
  },
  "AllowedHosts": "*"
}