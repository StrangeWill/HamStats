# Copy this file to .env and fill in your values.
# .env is git-ignored and loaded automatically by docker-compose.

# ── Image tag (roushtech/hamstats:<VERSION>) ──────────────────────────────────
# VERSION=stable

# ── Host ports ────────────────────────────────────────────────────────────────
# HTTP dashboard / API
# HTTP_PORT=80
# UDP port N1MM+ broadcasts to (must match your N1MM+ broadcast config)
# N1MM_PORT=12060
